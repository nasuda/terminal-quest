{
  "name": "terminal-quest",
  "version": "1.0.2",
  "description": "ストーリー駆動型ターミナルコマンド学習CLI - Learn terminal commands through interactive stories",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "terminal-quest": "bin/terminal-quest.js"
  },
  "files": [
    "bin/",
    "dist/",
    "!dist/**/*.test.*",
    "!dist/**/*.map",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "terminal",
    "cli",
    "learning",
    "tutorial",
    "command-line",
    "interactive",
    "japanese",
    "education"
  ],
  "author": "nasuda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nasuda/terminal-quest.git"
  },
  "homepage": "https://github.com/nasuda/terminal-quest",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
